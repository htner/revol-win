<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="xproto"
	ProjectGUID="{B0222EDF-55BD-4EAD-8A72-D87C2AB88CC8}"
	RootNamespace="protocol"
	Keyword="Win32Proj">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="../client/bin"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfATL="0"
			CharacterSet="1">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="0"
				AdditionalIncludeDirectories="../;../include;../include/client;../include/common;../include/third"
				PreprocessorDefinitions="WIN32;_DEBUG;_LIB;NOLAYERS;NSOX_WIN32;WIN32_CLIETN_PROTO"
				MinimalRebuild="TRUE"
				RuntimeLibrary="3"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="0"
				DebugInformationFormat="3"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="ssleay32.lib libeay32.lib ws2_32.lib wininet.lib rpcrt4.lib zlibd.lib"
				OutputFile="$(OutDir)/xproto_d.dll"
				AdditionalLibraryDirectories="../lib;../client/lib"
				GenerateDebugInformation="TRUE"
				ProgramDatabaseFile="$(OutDir)/$(ProjectName)_d.pdb"
				ImportLibrary="../client/lib/xproto_d.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"
				CommandLine="&quot;$(SolutionDir)tools\AutoBuildVer.exe&quot; &quot;$(SolutionDir)autover\$(ProjectName).autover&quot; 1
SubWCRev.exe . version.h.in version.h
"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
		<Configuration
			Name="Release|Win32"
			OutputDirectory="../client/bin"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			CharacterSet="1"
			WholeProgramOptimization="TRUE">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="1"
				GlobalOptimizations="TRUE"
				AdditionalIncludeDirectories="../;../include;../include/client;../include/common;../include/third"
				PreprocessorDefinitions="WIN32;NDEBUG;_LIB;NOLAYERS;NSOX_WIN32;WIN32_CLIETN_PROTO"
				RuntimeLibrary="2"
				EnableFunctionLevelLinking="TRUE"
				UsePrecompiledHeader="0"
				DebugInformationFormat="3"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="ssleay32.lib libeay32.lib ws2_32.lib wininet.lib rpcrt4.lib zlib.lib json.lib"
				OutputFile="$(OutDir)/xproto.dll"
				AdditionalLibraryDirectories="../lib;../client/lib"
				GenerateDebugInformation="TRUE"
				OptimizeReferences="2"
				EnableCOMDATFolding="2"
				ImportLibrary="../client/lib/xproto.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"
				CommandLine="&quot;$(SolutionDir)tools\AutoBuildVer.exe&quot; &quot;$(SolutionDir)autover\$(ProjectName).autover&quot; 1"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
