			Name="Release(Optimized)|Win32"
			OutputDirectory="../bin"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			CharacterSet="1"
			WholeProgramOptimization="TRUE">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="3"
				GlobalOptimizations="TRUE"
				FavorSizeOrSpeed="1"
				AdditionalIncludeDirectories="../../include; ../../include/common; ../../include/third"
				PreprocessorDefinitions="WIN32;NDEBUG;_LIB;NOLAYERS;NSOX_WIN32"
				RuntimeLibrary="2"
				EnableFunctionLevelLinking="TRUE"
				UsePrecompiledHeader="0"
				DebugInformationFormat="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="ssleay32.lib libeay32.lib ws2_32.lib wininet.lib rpcrt4.lib polib.lib"
				OutputFile="$(OutDir)/xproto.dll"
				AdditionalLibraryDirectories="../lib"
				OptimizeReferences="2"
				EnableCOMDATFolding="2"
				ImportLibrary="../lib/xproto.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
